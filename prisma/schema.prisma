// AgencyCheck — Prisma Schema v5 (PostgreSQL / Supabase)
// All enum fields stored as String for portability.
// Arrays/objects stored as String (JSON-serialised) for compatibility.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Transaction pooler (port 6543) — used by the app and Prisma Client at runtime
  url       = env("DATABASE_URL")
  // Direct connection (port 5432) — used only by `prisma db push` / `prisma migrate`
  // Required because PgBouncer (pooler) does not support schema migration commands
  directUrl = env("DIRECT_URL")
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Agency {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  website     String?
  email       String?
  phone       String?
  logoUrl     String?

  // Housing & transport — values: "YES" | "NO" | "UNKNOWN"
  housing     String  @default("UNKNOWN")
  housingType String  @default("UNKNOWN")
  transport   String  @default("UNKNOWN")

  // Location
  city             String  @default("unknown")
  cities           String  @default("[]")

  // Enriched fields
  jobTypes         String?
  salaryRange      String?

  // Structured classification (v4)
  agencyType        String  @default("general-staffing")
  jobFocus          String  @default("[]")
  transparencyScore Int     @default(0)
  accommodation     String  @default("unknown")
  supportedCities   String  @default("[]")

  // Deduplication & provenance
  canonicalId      String?
  aliases          String  @default("[]")
  duplicateCount   Int     @default(1)
  confidenceScore  Int     @default(100)
  sourceUrl        String?
  // values: "ABU_REGISTER" | "SNCU_REGISTER" | "OFFICIAL_WEBSITE" | "WORKER_REPORTED" | "UNKNOWN"
  sourceType       String  @default("UNKNOWN")
  lastCheckedAt    DateTime?

  housingVerification   String?
  transportVerification String?
  webPages              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobListings   JobListing[]
  reviews       Review[]
  salaryReports SalaryReport[]
  issueReports  IssueReport[]
  score         AgencyScore?
  mentions      ReviewMention[]
  cityMentions  AgencyCityMention[]

  @@map("agencies")
}

// ─── Job Listings ─────────────────────────────────────────────────────────────

model JobListing {
  id          String  @id @default(cuid())
  slug        String  @unique

  title       String
  jobType     String
  description String?

  city     String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  agencyId String

  salaryMin Float
  salaryMax Float

  // values: "YES" | "NO" | "UNKNOWN"
  housing   String @default("UNKNOWN")
  transport String @default("UNKNOWN")

  sourceUrl String?
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencyId])
  @@index([city])
  @@index([jobType])
  @@index([isActive])
  @@map("job_listings")
}

model Review {
  id String @id @default(cuid())

  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  agencyId String

  // values: "PENDING" | "APPROVED" | "REJECTED" | "PUBLISHED"
  status        String  @default("PENDING")
  isPublished   Boolean @default(false)
  internalNotes String?
  moderatedAt   DateTime?
  moderatedBy   String?

  // values: "ANONYMOUS" | "VERIFIED_WORKER"
  reviewType String @default("ANONYMOUS")

  // values: "CURRENT" | "FORMER" | "UNKNOWN"
  workerStatus     String @default("UNKNOWN")
  experiencePeriod String?

  jobType  String?
  jobTitle String?
  city     String?
  title    String?

  overallRating Int @default(3)

  salaryRating          Int  @default(3)
  housingRating         Int?
  managementRating      Int  @default(3)
  contractClarityRating Int  @default(3)
  transportRating       Int?
  salaryAccuracyRating  Int?

  // values: "YES" | "NO" | "UNKNOWN"
  accommodationProvided String @default("UNKNOWN")
  // values: "PRIVATE" | "SHARED" | "UNKNOWN"
  roomType              String @default("UNKNOWN")
  weeklyRent            Float?
  peopleInHouse         Int?

  // values: "YES" | "NO" | "UNSURE"
  wouldRecommend String  @default("UNSURE")
  comment        String?

  issueTags String @default("[]")

  // values: "VERIFIED" | "WORKER_REPORTED" | "UNKNOWN"
  verificationStatus String @default("UNKNOWN")
  // values: "ABU_REGISTER" | "SNCU_REGISTER" | "OFFICIAL_WEBSITE" | "WORKER_REPORTED" | "UNKNOWN"
  sourceType         String @default("WORKER_REPORTED")

  createdAt DateTime @default(now())

  photos   ReviewPhoto[]
  mentions ReviewMention[]
  comments ReviewComment[]

  @@index([agencyId])
  @@index([status])
  @@index([isPublished])
  @@index([overallRating])
  @@map("reviews")
}

// ─── Review Comments — public comments left on a review ──────────────────────

model ReviewComment {
  id         String   @id @default(cuid())

  review     Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reviewId   String

  agencyName String
  city       String
  body       String   @db.Text

  createdAt  DateTime @default(now())

  @@index([reviewId])
  @@index([createdAt])
  @@map("review_comments")
}

// ─── Admin Notifications ──────────────────────────────────────────────────────

model AdminNotification {
  id        String   @id @default(cuid())

  // e.g. "review_comment" | "new_review"
  type      String

  title     String
  // JSON-encoded metadata (agency name, city, review id, preview, etc.)
  metadata  String   @default("{}")

  isRead    Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([isRead])
  @@index([createdAt])
  @@map("admin_notifications")
}

// ─── Review Mentions — agencies extracted from review text ───────────────────

model ReviewMention {
  id      String @id @default(cuid())

  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reviewId String

  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  agencyId String

  // Raw text fragment that triggered the match
  extractedName   String
  // "exact_match" | "fuzzy_match" | "text_extraction"
  detectionMethod String  @default("text_extraction")
  // 0–100; higher = more confident
  confidence      Int     @default(50)
  // true when agency record was created by this extraction (did not exist before)
  autoCreated     Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([reviewId, agencyId])
  @@index([reviewId])
  @@index([agencyId])
  @@map("review_mentions")
}

// ─── Review Photos ────────────────────────────────────────────────────────────

model ReviewPhoto {
  id String @id @default(cuid())

  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reviewId String

  fileUrl   String
  fileName  String
  fileType  String
  fileSize  Int

  caption   String?
  sortOrder Int @default(0)

  uploadedAt DateTime @default(now())

  @@index([reviewId])
  @@map("review_photos")
}

model SalaryReport {
  id String @id @default(cuid())

  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  agencyId String

  jobTitle  String
  city      String
  hourlyPay Float
  // values: "YES" | "NO" | "UNKNOWN"
  housing   String @default("UNKNOWN")

  createdAt DateTime @default(now())

  @@map("salary_reports")
}

model IssueReport {
  id String @id @default(cuid())

  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  agencyId String

  // values: "MISSING_OVERTIME" | "MISSING_SUNDAY_PAY" | "LATE_PAYMENT" | "BAD_HOUSING" | "CONTRACT_ISSUE" | "TRANSPORT_ISSUE" | "PAYSLIP_PROBLEM"
  issueType     String
  description   String
  amountMissing Float?
  // values: "OPEN" | "RESOLVED" | "DISMISSED"
  status        String @default("OPEN")

  createdAt DateTime @default(now())

  @@map("issue_reports")
}

model AgencyScore {
  id String @id @default(cuid())

  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  agencyId String @unique

  score Int @default(100)

  updatedAt DateTime @updatedAt

  @@map("agency_scores")
}

// ─── Lead Capture ─────────────────────────────────────────────────────────────

model Lead {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sourcePage  String
  // values: "jobs_with_housing" | "job_page" | "agency_page" | "general_apply"
  sourceType  String  @default("general_apply")
  sourceSlug  String?
  sourceLabel String?

  fullName     String
  phone        String
  email        String?
  whatsappSame Boolean @default(false)

  nationality    String?
  currentCountry String?
  alreadyInNL    Boolean?

  preferredWorkType   String?
  preferredRegion     String?
  accommodationNeeded Boolean?
  driversLicense      Boolean?
  canWorkWeekends     Boolean?
  experienceLevel     String?
  availableFrom       DateTime?
  notes               String?

  // values: "new" | "reviewed" | "waiting_for_match" | "potential_fit" | "agency_contact_pending" | "approved" | "sent" | "converted" | "confirmed" | "paid" | "rejected"
  status          String @default("new")
  tags            String @default("[]")
  assignedTo      String?
  lastContactedAt DateTime?
  internalNotes   String?

  assignedAgencies String    @default("[]")
  sentAt           DateTime?

  // ── Lead qualification (post-submit step) ─────────────────────────────────
  // values: "immediately" | "1_2_weeks" | "1_month" | "exploring"
  availability   String?
  // values: "nl" | "relocate" | "exploring"
  locationStatus String?
  // 10–100: computed from availability + locationStatus
  leadScore      Int?

  // ── Payout / conversion tracking ──────────────────────────────────────────
  // confirmedAt: date worker was confirmed as started at agency
  // workerStartDate: actual first working day (if known)
  // payoutAmount: agreed fee in EUR (e.g. €150 per placed worker)
  // paidAt: date payment was received from agency
  confirmedAt     DateTime?
  workerStartDate DateTime?
  payoutAmount    Float?
  paidAt          DateTime?

  sends LeadSend[]

  @@index([status])
  @@index([createdAt])
  @@index([sourceType])
  @@index([accommodationNeeded])
  @@map("leads")
}

// ─── Worker Experience Reports ────────────────────────────────────────────────
// Anonymous salary/housing transparency reports submitted by workers.

model WorkerExperience {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  agencyName String
  city       String
  jobType    String

  agreedGross String?   // what agency advertised
  actualKeep  String?   // what worker actually kept

  hasHousing     Boolean @default(false)
  housingRating  Int?    // 1–5 if hasHousing

  salaryAccurate Boolean @default(false)
  wouldRecommend Boolean @default(false)

  comment     String?
  submittedAt String?   // ISO string from client

  @@index([agencyName])
  @@index([createdAt])
  @@map("worker_experiences")
}

// ─── Lead Send Log ─────────────────────────────────────────────────────────────

model LeadSend {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId String

  agencySlug  String
  agencyName  String
  agencyEmail String?

  method   String @default("email")
  status   String @default("sent")
  errorMsg String?

  emailSubject String?
  emailBody    String?

  @@index([leadId])
  @@map("lead_sends")
}

// ─── Pre-Qualification Gate ───────────────────────────────────────────────────
// Stores every EU citizen + BSN check before the Apply/WhatsApp button is shown.
// Used for analytics: total attempts, qualified, rejected.

model PreQualification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Job context
  jobId    String?  // slug or listing id, e.g. "warehouse", "reachtruck"
  jobTitle String?

  // Answers
  isEuCitizen Boolean
  hasBsn      Boolean

  // Computed gate result: true only when isEuCitizen && hasBsn
  qualified Boolean

  // Tracking slug passed from apply page (same as ApplyPreScreen `source` prop)
  source String?

  @@index([createdAt])
  @@index([qualified])
  @@index([jobId])
  @@map("pre_qualifications")
}

// ─── Recruiter Config — round-robin recruiter list (managed via raw SQL in lib/recruiter-db.ts) ──
// Added to schema so prisma db push does not drop the table.

model RecruiterConfig {
  id        String   @id
  name      String
  waUrl     String
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@map("recruiter_config")
}

// ─── Referral Clicks — every recruiter redirect logged here ──────────────────────
// Added to schema so prisma db push does not drop the table (89 rows).

model ReferralClick {
  id          String   @id
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  recruiter   String
  recruiterWa String
  jobId       String?
  jobTitle    String?
  source      String   @default("AgencyCheck")

  @@index([createdAt], name: "rc_created_at_idx")
  @@index([recruiter],  name: "rc_recruiter_idx")
  @@index([jobId],      name: "rc_job_id_idx")
  @@map("referral_clicks")
}

// ─── Candidate Reliability Notes — private admin-only notes on candidate behaviour ──
// Added to schema so prisma db push does not drop the table.

model CandidateReliabilityNote {
  id              String    @id
  leadId          String
  candidateName   String
  noteType        String
  severity        String    @default("medium")
  recruiterSource String?
  incidentDate    DateTime? @db.Date
  noteText        String?
  createdByAdmin  String?
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)

  @@index([leadId],    name: "crn_lead_id_idx")
  @@index([severity],  name: "crn_severity_idx")
  @@index([noteType],  name: "crn_note_type_idx")
  @@index([createdAt], name: "crn_created_at_idx")
  @@map("candidate_reliability_notes")
}

// ─── Candidate Restrictions — blocked phone numbers (admin-managed) ───────────────
// Added to schema so prisma db push does not drop the table.

model CandidateRestriction {
  id              String    @id
  phoneNormalized String
  phoneRaw        String
  reasonCategory  String
  severity        String    @default("medium")
  internalNote    String?
  recruiterName   String?
  dateReported    DateTime? @db.Date
  active          Boolean   @default(true)
  createdByAdmin  String?
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)

  @@index([phoneNormalized], name: "cr_phone_idx")
  @@index([active],          name: "cr_active_idx")
  @@map("candidate_restrictions")
}

// ─── Restriction Blocked Attempts — log of every blocked apply attempt ────────────

model RestrictionBlockedAttempt {
  id                String   @id
  restrictionId     String
  phoneNormalized   String
  attemptedJobId    String?
  attemptedJobTitle String?
  source            String   @default("AgencyCheck")
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime @default(now()) @db.Timestamptz(6)

  @@index([restrictionId], name: "rba_restriction_idx")
  @@index([createdAt],     name: "rba_created_at_idx")
  @@map("restriction_blocked_attempts")
}

// ─── Phone Application Log — persistent dedup across devices and sessions ────────
// Stores normalised phone numbers of successful WhatsApp apply events.
// Checked by /api/check-phone (read) and written by /api/apply-webhook (write).
// Prevents the same phone from submitting more than once every 24 h,
// even across incognito mode, different devices, or Vercel cold starts.

model PhoneApplication {
  id        String   @id @default(cuid())
  phone     String   // normalised: lowercase, spaces/dashes/brackets stripped
  jobId     String?
  source    String?
  createdAt DateTime @default(now())

  @@index([phone])
  @@index([createdAt])
  @@map("phone_applications")
}

// ─── Agency City Mentions — cities extracted from worker comments ──────────────
// Tracks which cities workers mention for a given agency.
// Powers "Cities workers mention" SEO sections on agency pages.

model AgencyCityMention {
  id             String   @id @default(cuid())

  agency         Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  agencyId       String

  // Normalised key for deduplication: lowercase + trimmed
  cityNormalized String
  // Original casing from first mention (for display)
  cityDisplay    String

  mentionCount   Int      @default(1)

  firstSeenAt    DateTime @default(now())
  lastSeenAt     DateTime @default(now())

  @@unique([agencyId, cityNormalized])
  @@index([agencyId])
  @@index([mentionCount])
  @@map("agency_city_mentions")
}

// ─── Apply Funnel Events — step-by-step tracking of the apply modal ──────────
// Every apply attempt fires a series of events that can be replayed to find
// exactly where candidates dropped off.
//
// event values:
//   "open"              — modal opened (step: "gate")
//   "gate_passed"       — EU citizenship confirmed, moved to step 2
//   "details_a_passed"  — BSN/driving/housing/avail filled, moved to step 3
//   "completed"         — WhatsApp opened (step: "complete")
//   "abandoned"         — modal closed mid-flow (step = last screen seen)
//   "disqualified"      — non-EU / already applied / BSN blocked, etc.

model ApplyFunnelEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Client-generated UUID per open — groups all events for one apply attempt
  sessionId String
  event     String
  // "gate" | "details_a" | "details_b" | "geo_blocked" | "already_applied" | "complete"
  step      String
  jobId     String?
  source    String?

  @@index([sessionId])
  @@index([createdAt])
  @@index([event])
  @@map("apply_funnel_events")
}
