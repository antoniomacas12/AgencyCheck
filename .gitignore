# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# TypeScript
*.tsbuildinfo

# User-uploaded files — stored on server, not committed
# The directory itself is tracked via .gitkeep
public/uploads/reviews/*
!public/uploads/reviews/.gitkeep
