# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required for reviews, leads, and all DB features)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/agencycheck?schema=public"

# Quick local setup (Docker):
#   docker run -d --name agencycheck-db -e POSTGRES_PASSWORD=secret -e POSTGRES_DB=agencycheck -p 5432:5432 postgres:15
#   DATABASE_URL="postgresql://postgres:secret@localhost:5432/agencycheck"

# ─── Admin authentication ──────────────────────────────────────────────────────
ADMIN_EMAIL="admin@agencycheck.nl"
ADMIN_PASSWORD="CHANGE_THIS_PASSWORD"
# Must be at least 32 random characters — used to sign session cookies
ADMIN_SESSION_SECRET="replace-with-32-plus-random-chars-here-12345678"

# ─── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ─── Sentry error monitoring ──────────────────────────────────────────────────
# Get these from: sentry.io → Your Project → Settings → SDK Setup
# SENTRY_DSN          — server-side DSN (keep secret, never expose in browser)
# NEXT_PUBLIC_SENTRY_DSN — browser-side DSN (same value, public is fine)
# SENTRY_AUTH_TOKEN   — for source map uploads during Vercel build (optional but recommended)
# SENTRY_ORG          — your Sentry organisation slug
# SENTRY_PROJECT      — your Sentry project slug
SENTRY_DSN="https://xxx@oXXX.ingest.sentry.io/XXXXX"
NEXT_PUBLIC_SENTRY_DSN="https://xxx@oXXX.ingest.sentry.io/XXXXX"
SENTRY_AUTH_TOKEN="sntrys_..."
SENTRY_ORG="your-org-slug"
SENTRY_PROJECT="your-project-slug"

# ─── Optional: email notifications ────────────────────────────────────────────
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="noreply@agencycheck.nl"
# SMTP_PASS="your-smtp-password"
# NOTIFY_EMAIL="admin@agencycheck.nl"
